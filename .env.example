# OpenRouter — openrouter.ai → Keys → Create Key (modelos free = custo zero)
OPENROUTER_API_KEY=

# Cadeias de modelos (vírgula = fallback). IDs ":free" mudam — confira em openrouter.ai/models (filtro Free)
OPENROUTER_MODELS_ANALYZER=deepseek/deepseek-chat:free,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODELS_WRITER=deepseek/deepseek-chat:free,meta-llama/llama-3.3-70b-instruct:free

# Máximo de cover letters/propostas geradas por execução (default 5)
MAX_COVER_LETTERS=5

# Resend — resend.com → API Keys → Create API Key
RESEND_API_KEY=

# Freelancer.com — developers.freelancer.com → My Apps → OAuth 2.0
FREELANCER_TOKEN=

# Filtro de recência do LinkedIn (r86400 = 24h, r604800 = 7 dias)
LINKEDIN_DATE_POSTED=r86400

# E-mail remetente para vagas de emprego (deve estar verificado no Resend)
JOB_EMAIL_FROM=vagas@seudominio.com

# E-mail destinatário para vagas de emprego
JOB_EMAIL_TO=seu-email@exemplo.com

# E-mail remetente para projetos freelance (deve estar verificado no Resend)
FREELANCE_EMAIL_FROM=freelance@seudominio.com

# E-mail destinatário para projetos freelance
FREELANCE_EMAIL_TO=seu-email@exemplo.com
